# 1. 백엔드 애플리케이션 배포 설정 (Deployment)
apiVersion: apps/v1
kind: Deployment
metadata:
  name: modu-backend
  namespace: modu-apps
  labels:
    app: backend
spec:
  # [고가용성] 서버 부하 분산 및 무중단 운영을 위해 2개의 포드를 유지합니다.
  replicas: 2 
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      # [인증] ECR 프라이빗 리포지토리 접근 권한을 위해 생성한 'regcred' 시크릿을 사용합니다.
      # 이 설정이 누락되면 'ImagePullBackOff' 에러가 발생합니다.
      imagePullSecrets:
      - name: regcred
      containers:
      - name: backend
        # [자동화] Jenkinsfile의 sed 명령어(s|BACKEND_IMAGE|...)가 이 자리에 실제 이미지 주소와 태그를 주입합니다.
        # 태그가 꼬이지 않도록 '_PLACEHOLDER'를 제거한 순수 키워드만 남겨두었습니다.
        image: BACKEND_IMAGE
        ports:
        - containerPort: 8080 # 애플리케이션(Spring Boot 등)이 내부에서 사용하는 포트
        # modu-secret의 모든 키를 환경변수로 주입합니다
        envFrom:
        - secretRef:
            name: modu-secret
        resources:
          # Spring Boot JVM(~300Mi) + Kafka 컨슈머/프로듀서 + JPA + SSE 연결 유지
          # 거래시간 burst 대응 위해 limits 여유 확보.
          requests:
            memory: "768Mi"
            cpu: "300m"
          limits:
            memory: "1536Mi"
            cpu: "1500m"
        # Pod가 트래픽 받을 준비가 됐는지 확인 — 준비 전까지 트래픽 차단
        readinessProbe:
          httpGet:
            path: /actuator/health/readiness
            port: 8080
          initialDelaySeconds: 30  # Spring Boot 기동 시간 여유
          periodSeconds: 10
        # Pod가 살아있는지 확인 — 실패 시 자동 재시작
        livenessProbe:
          httpGet:
            path: /actuator/health/liveness
            port: 8080
          initialDelaySeconds: 60  # readiness보다 여유있게 설정
          periodSeconds: 15

---

# 2. 백엔드 내부 통신을 위한 서비스 설정 (Service)
apiVersion: v1
kind: Service
metadata:
  name: backend-service
  namespace: modu-apps
spec:
  selector:
    app: backend # 위의 Deployment 라벨과 일치하여 트래픽을 전달합니다.
  ports:
  - protocol: TCP
    port: 80       # 서비스가 클러스터 내부에서 노출할 포트
    targetPort: 8080 # 실제 컨테이너 내부로 전달할 포트
  # [보안/설계] 백엔드는 외부 노출 없이 클러스터 내부(프론트엔드 -> 백엔드) 통신만 허용하는 ClusterIP 타입을 사용합니다.
  type: ClusterIP

---

# 3. PodDisruptionBudget — 노드 drain/유지보수 시 최소 1개 backend 가용 보장.
# replicas 2 라 K8s 가 한 번에 둘 다 evict 하지 못하게 막아 무중단 보장.
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: backend-pdb
  namespace: modu-apps
spec:
  minAvailable: 1
  selector:
    matchLabels:
      app: backend