pipeline {
    agent any

    environment {
        // 1. 인프라 공통 설정
        AWS_REGION           = 'ap-northeast-2'
        
        // 2. 젠킨스 자격 증명 ID
        AWS_CRED_ID          = 'aws-credentials'
        REGISTRY_BE_ID       = 'ecr-registry-backend'
        REGISTRY_FE_ID       = 'ecr-registry-frontend'
        
        // 3. 쿠버네티스 접근 설정 ID
        K3S_CONFIG_ID        = 'k3s-config.yaml'
        EKS_CONFIG_ID        = 'aws-eks-config'
        
        // 4. K8s 매니페스트 파일 경로
        K8S_DIR              = 'infra/k8s'
        
        // 5. 알림 및 트러블슈팅용 변수
        FAILED_STAGE         = ""
        ERROR_DETAILS        = ""
    }

    stages {
        stage('1. 준비: 코드 가져오기') {
            steps {
                script { env.FAILED_STAGE = "1. 코드 체크아웃" }
                checkout scm
            }
        }

        stage('2. 빌드: 컨테이너 이미지 생성 및 푸시') {
            steps {
                script {
                    withCredentials([
                        string(credentialsId: "${REGISTRY_BE_ID}", variable: 'FULL_URI_BE'),
                        string(credentialsId: "${REGISTRY_FE_ID}", variable: 'FULL_URI_FE')
                    ]) {
                        def domainPart = FULL_URI_BE.substring(0, FULL_URI_BE.lastIndexOf('/'))
                        def registryDomain = domainPart.startsWith('http') ? domainPart : "https://${domainPart}"
                        
                        docker.withRegistry("${registryDomain}", "ecr:${AWS_REGION}:${AWS_CRED_ID}") {
                            // [Backend 빌드 및 푸시]
                            try {
                                env.FAILED_STAGE = "2-1. 백엔드 빌드"
                                sh 'cd backend && docker build -t $FULL_URI_BE:$BUILD_NUMBER . 2> be_err.log'
                                sh 'docker push $FULL_URI_BE:$BUILD_NUMBER'
                            } catch (Exception e) {
                                env.ERROR_DETAILS = sh(script: '[ -f backend/be_err.log ] && tail -n 10 backend/be_err.log || echo "백엔드 빌드 실패"', returnStdout: true).trim()
                                error "Backend Build Failed"
                            }

                            // [Frontend 빌드 및 푸시]
                            try {
                                env.FAILED_STAGE = "2-2. 프론트엔드 빌드"
                                sh 'cd frontend && docker build -t $FULL_URI_FE:$BUILD_NUMBER . 2> fe_err.log'
                                sh 'docker push $FULL_URI_FE:$BUILD_NUMBER'
                            } catch (Exception e) {
                                env.ERROR_DETAILS = sh(script: '[ -f frontend/fe_err.log ] && tail -n 10 frontend/fe_err.log || echo "프론트 빌드 실패"', returnStdout: true).trim()
                                error "Frontend Build Failed"
                            }
                        }
                    }
                }
            }
        }

        stage('3. 배포: SSAFY K3s (Develop)') {
            when { branch 'develop' } 
            steps {
                script { 
                    env.FAILED_STAGE = "3. SSAFY K3s 배포"
                    deployToCluster("${K3S_CONFIG_ID}", "SSAFY K3s") 
                }
            }
        }

        stage('4. 배포: AWS EKS (Main)') {
            when { branch 'main' }
            steps {
                script { 
                    env.FAILED_STAGE = "4. AWS EKS 배포"
                    deployToCluster("${EKS_CONFIG_ID}", "AWS EKS") 
                }
            }
        }
    }

    post {
        success {
            script {
                def successMsg = (env.BRANCH_NAME == 'develop') ? 
                    "🚀 SSAFY K3s(Develop) 환경 배포에 성공했습니다!" : 
                    "🌟 AWS EKS(Main) 운영 환경 배포에 성공했습니다!"
                env.FAILED_STAGE = "" 
                sendMattermostNotification("SUCCESS", "#00FF00", successMsg)
            }
        }
        failure {
            sendMattermostNotification("FAILURE", "#FF0000", "🚨 상세 원인: ${env.ERROR_DETAILS}")
        }
        always {
            sh "docker image prune -f"
        }
    }
}

/**
 * [핵심 수정] 하이브리드 도구 접근법을 이용한 배포 함수
 * amazon/aws-cli 이미지를 베이스로 사용하고, kubectl을 실시간으로 설치하여 의존성 문제를 해결합니다.
 */
def deployToCluster(String configId, String clusterName) {
    try {
        // [수정] AWS CLI가 내장된 공식 이미지를 배포 환경으로 선택
        docker.image('amazon/aws-cli:latest').inside('--network host --entrypoint=""') {
            withCredentials([
                file(credentialsId: configId, variable: 'KUBECONFIG'),
                string(credentialsId: "${REGISTRY_BE_ID}", variable: 'FULL_URI_BE'),
                string(credentialsId: "${REGISTRY_FE_ID}", variable: 'FULL_URI_FE'),
                // AWS 명령 실행을 위한 IAM 자격 증명 주입
                usernamePassword(credentialsId: "${AWS_CRED_ID}", usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')
            ]) {
                sh '''
                # 1. kubectl 바이너리 동적 설치 (Amazon Linux 환경)
                # 단일 바이너리라 다운로드 속도가 매우 빠르며, 의존성 충돌이 없습니다.
                curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
                chmod +x kubectl
                mv kubectl /usr/local/bin/

                # 2. 네임스페이스 생성 및 ECR 인증 시크릿(regcred) 자동 갱신
                # 배포 시마다 12시간 유효한 새 토큰을 발급받아 주입하므로 '인증 실패'를 영구적으로 방지합니다.
                kubectl --kubeconfig=$KUBECONFIG apply -f $K8S_DIR/00_namespace.yaml
                
                kubectl --kubeconfig=$KUBECONFIG delete secret regcred -n modu-apps --ignore-not-found
                kubectl --kubeconfig=$KUBECONFIG create secret docker-registry regcred \
                  --docker-server=338330655332.dkr.ecr.ap-northeast-2.amazonaws.com \
                  --docker-username=AWS \
                  --docker-password=$(aws ecr get-login-password --region ap-northeast-2) \
                  -n modu-apps
                
                # 3. 매니페스트 이미지 태그 치환 (idempotency 보장)
                # sed 명령어가 BACKEND_IMAGE 문자열을 빌드 태그가 포함된 실제 주소로 바꿉니다.
                sed -i "s|BACKEND_IMAGE|$FULL_URI_BE:$BUILD_NUMBER|g" $K8S_DIR/backend.yaml
                sed -i "s|FRONTEND_IMAGE|$FULL_URI_FE:$BUILD_NUMBER|g" $K8S_DIR/frontend.yaml
                
                # 4. 최종 배포 실행
                kubectl --kubeconfig=$KUBECONFIG apply -f $K8S_DIR/
                '''
            }
        }
    } catch (Exception e) {
        env.ERROR_DETAILS = "${clusterName} 배포 실패: AWS/K8s 도구 연동 또는 권한 오류"
        error "Deployment Failed"
    }
}

/**
 * Mattermost 상세 알림 전송 함수 (기존 로직 유지)
 */
def sendMattermostNotification(String status, String color, String message) {
    def decodedJobName = java.net.URLDecoder.decode(env.JOB_NAME, "UTF-8")
    def displayStage = (env.FAILED_STAGE && env.FAILED_STAGE != "null") ? env.FAILED_STAGE : "성공"

    withCredentials([string(credentialsId: 'MATTERMOST_WEBHOOK_URL', variable: 'WEBHOOK_URL')]) {
        def title = (status == "SUCCESS") ? "✅ 파이프라인 공정 성공" : "🚨 파이프라인 공정 실패"
        def payload = """
        {
            "attachments": [
                {
                    "color": "${color}",
                    "title": "${title}",
                    "text": "**프로젝트:** ${decodedJobName} (#${env.BUILD_NUMBER})\\n**상태:** ${displayStage}",
                    "fields": [
                        {
                            "short": false,
                            "title": "결과 리포트",
                            "value": "```\\n${message}\\n```"
                        },
                        {
                            "short": false,
                            "title": "워크플로우 확인",
                            "value": "[👉 젠킨스 콘솔 로그 보기](${env.BUILD_URL}console)"
                        }
                    ]
                }
            ]
        }
        """
        sh "curl -i -X POST -H 'Content-Type: application/json' -d '${payload}' ${WEBHOOK_URL}"
    }
}