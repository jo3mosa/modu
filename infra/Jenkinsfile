pipeline {
    // 실행 가능한 모든 에이전트(Worker Node)에서 파이프라인을 실행합니다.
    agent any

    // 전역 변수 설정: 중복되는 문자열을 상수로 관리하여 휴먼 에러를 방지합니다.
    environment {
        // 인프라 공통 설정 (AWS 리전 및 ECR 리포지토리 이름)
        AWS_REGION           = 'ap-northeast-2'
        ECR_BACKEND_NAME     = 'modu-backend'
        ECR_FRONTEND_NAME    = 'modu-frontend'
        
        // 젠킨스 Credentials ID (Jenkins 관리 > Credentials에 등록된 고유 ID)
        AWS_CRED_ID          = 'aws-credentials'
        GITHUB_CRED_ID       = 'github-token'
        
        // 환경별 쿠버네티스 설정 파일 ID (Kubeconfig 파일을 Secret File로 등록한 ID)
        K3S_CONFIG_ID        = 'k3s-config.yaml' // SSAFY 교육용 서버용
        EKS_CONFIG_ID        = 'aws-eks-config'  // AWS 운영 서버용
        
        // AWS ECR 레지스트리 주소 (Secret Text로 등록된 ECR 엔드포인트 ID)
        REGISTRY_BE_ID       = 'ecr-registry-backend'
        REGISTRY_FE_ID       = 'ecr-registry-frontend'
        
        // 쿠버네티스 매니페스트(.yaml) 파일들이 위치한 프로젝트 내 경로
        K8S_DIR              = 'infra/k8s'
    }

    stages {
        // 1단계: 소스 코드 체크아웃
        stage('1. 준비: 코드 가져오기') {
            steps {
                // Git에 설정된 현재 브랜치의 최신 소스 코드를 작업 디렉토리로 가져옵니다.
                checkout scm
            }
        }

        // 2단계: Docker 이미지 빌드 및 ECR 푸시 (CI 프로세스)
        stage('2. 빌드: 컨테이너 이미지 생성 및 푸시') {
            steps {
                script {
                    // 보안 자격 증명을 환경 변수로 바인딩합니다.
                    withCredentials([
                        string(credentialsId: "${REGISTRY_BE_ID}", variable: 'URL_BE'),
                        string(credentialsId: "${REGISTRY_FE_ID}", variable: 'URL_FE'),
                        /**
                         * [최종 수정] NoSuchMethodError 해결을 위해 usernamePassword 방식을 사용합니다.
                         * 이 방식은 'Username with password' 타입과 'AWS Credentials' 타입 모두 호환됩니다.
                         * Access Key -> usernameVariable, Secret Key -> passwordVariable에 매핑됩니다.
                         */
                        usernamePassword(
                            credentialsId: "${AWS_CRED_ID}", 
                            usernameVariable: 'AWS_ACCESS_KEY_ID', 
                            passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                        )
                    ]) {
                        // 백엔드 이미지 빌드 및 AWS ECR 로그인/푸시
                        // AWS CLI는 환경 변수로 등록된 AWS_ACCESS_KEY_ID를 자동으로 인식하여 인증합니다.
                        echo ">>> 백엔드 빌드 및 푸시 시작: ${BUILD_NUMBER}"
                        sh "docker build -t ${URL_BE}/${ECR_BACKEND_NAME}:${BUILD_NUMBER} ./backend"
                        sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${URL_BE}"
                        sh "docker push ${URL_BE}/${ECR_BACKEND_NAME}:${BUILD_NUMBER}"

                        // 프론트엔드 이미지 빌드 및 푸시
                        echo ">>> 프론트엔드 빌드 및 푸시 시작: ${BUILD_NUMBER}"
                        sh "docker build -t ${URL_FE}/${ECR_FRONTEND_NAME}:${BUILD_NUMBER} ./frontend"
                        sh "docker push ${URL_FE}/${ECR_FRONTEND_NAME}:${BUILD_NUMBER}"
                    }
                }
            }
        }

        // 3단계: SSAFY K3s 서버 배포 (Develop CD)
        stage('3. 배포: SSAFY K3s (Develop)') {
            // develop 브랜치에 푸시되거나 머지되었을 때만 실행됩니다.
            when { branch 'develop' } 
            steps {
                // 하단에 정의된 쿠버네티스 배포 공통 함수를 호출합니다.
                deployToCluster("${K3S_CONFIG_ID}", "SSAFY K3s")
            }
        }

        // 4단계: AWS EKS 운영 서버 배포 (Main CD)
        stage('4. 배포: AWS EKS (Main)') {
            // main 브랜치에 코드가 반영되었을 때만 운영 서버 배포를 실행합니다.
            when { branch 'main' }
            steps {
                deployToCluster("${EKS_CONFIG_ID}", "AWS EKS")
            }
        }
    }

    // 파이프라인 종료 후(성공/실패 상관없이) 실행되는 정리 블록
    post {
        always {
            // 호스트 서버의 디스크 공간 확보를 위해 빌드 과정에서 생성된 임시 이미지를 정리합니다.
            sh "docker image prune -f"
        }
    }
}

/**
 * 쿠버네티스 클러스터 배포 공통 로직 함수
 * @param configId 젠킨스에 등록된 Kubeconfig(Secret File)의 ID
 * @param clusterName 로그 식별용 클러스터 명칭
 */
def deployToCluster(String configId, String clusterName) {
    script {
        echo ">>> ${clusterName} 배포 프로세스 시작 (Namespace: modu-apps)"
        withCredentials([
            file(credentialsId: configId, variable: 'KUBECONFIG'),
            string(credentialsId: "${REGISTRY_BE_ID}", variable: 'URL_BE'),
            string(credentialsId: "${REGISTRY_FE_ID}", variable: 'URL_FE')
        ]) {
            sh """
            # 1. 네임스페이스 격리: 애플리케이션 운영 공간인 modu-apps가 없다면 생성합니다.
            kubectl --kubeconfig=${KUBECONFIG} apply -f ${K8S_DIR}/00_namespace.yaml
            
            # 2. 동적 이미지 태깅: YAML 파일 내의 BACKEND_IMAGE/FRONTEND_IMAGE 문자열을
            # 현재 빌드된 실제 ECR 이미지 주소와 태그(${BUILD_NUMBER})로 치환합니다.
            sed -i 's|BACKEND_IMAGE|${URL_BE}/${ECR_BACKEND_NAME}:${BUILD_NUMBER}|g' ${K8S_DIR}/backend.yaml
            sed -i 's|FRONTEND_IMAGE|${URL_FE}/${ECR_FRONTEND_NAME}:${BUILD_NUMBER}|g' ${K8S_DIR}/frontend.yaml
            
            # 3. 전체 매니페스트 적용: infra/k8s 폴더 내의 모든 설정을 클러스터에 반영합니다.
            kubectl --kubeconfig=${KUBECONFIG} apply -f ${K8S_DIR}/
            """
        }
    }
}