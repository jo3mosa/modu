// ============================================================
// Jenkins CI/CD Pipeline
// - develop 브랜치 → SSAFY K3s 클러스터 배포
// - main 브랜치    → AWS EKS 운영 환경 배포
// - 변경된 서비스만 빌드 (git diff 기반 선택적 빌드)
// ============================================================
pipeline {
    // 사용 가능한 모든 Jenkins 에이전트에서 실행
    agent any

    options {
        // 같은 브랜치(Job)의 빌드가 동시에 돌면 같은 Docker 데몬/CPU를 두고 경쟁해
        // 빌드가 느려지고, post 의 prune 이 서로 충돌(아래 always 참고)하므로 직렬화한다.
        disableConcurrentBuilds()
    }

    environment {
        // BuildKit 활성화 — Dockerfile 의 캐시 마운트(--mount=type=cache)로
        // Gradle/npm 의존성을 빌드 간에 영속화해 재다운로드를 막는다.
        DOCKER_BUILDKIT = '1'

        // ── 인프라 공통 설정 ──────────────────────────────────
        // AWS 리전
        AWS_REGION     = 'ap-northeast-2'
        // Jenkins에 등록된 AWS IAM Credentials ID
        AWS_CRED_ID    = 'aws-credentials'
        // Jenkins에 등록된 ECR 백엔드 레지스트리 URI (Credentials ID)
        REGISTRY_BE_ID = 'ecr-registry-backend'
        // Jenkins에 등록된 ECR 프론트엔드 레지스트리 URI (Credentials ID)
        REGISTRY_FE_ID = 'ecr-registry-frontend'
        // Jenkins에 등록된 ECR AI Agent 레지스트리 URI (Credentials ID)
        REGISTRY_AI_ID = 'ecr-registry-ai-agent'
        // Jenkins에 등록된 ECR Analysis Server 레지스트리 URI (Credentials ID)
        REGISTRY_ANALYSIS_ID = 'ecr-registry-analysis'
        // Jenkins에 등록된 SSAFY K3s kubeconfig 파일 (Credentials ID)
        K3S_CONFIG_ID  = 'k3s-config.yaml'
        // Jenkins에 등록된 AWS EKS kubeconfig 파일 (Credentials ID)
        EKS_CONFIG_ID  = 'aws-eks-config'
        // k8s 매니페스트 파일이 위치한 디렉토리
        K8S_DIR        = 'infra/k8s'

        // ── 상태 관리 변수 ─────────────────────────────────────
        // 실패한 스테이지 이름을 저장 (Mattermost 알림에서 실패 지점 표시용)
        FAILED_STAGE   = ""
        // 실패 원인 상세 내용을 저장 (Mattermost 알림에서 상세 원인 표시용)
        ERROR_DETAILS  = ""

        // ── 선택적 빌드 플래그 ─────────────────────────────────
        // BUILD_BACKEND / BUILD_FRONTEND / BUILD_AI 는 Stage 1 의 script 블록에서
        // env.BUILD_* 로 동적 설정. environment {} 블록에서 초기화하면 immutable 이
        // 되어 script 의 재할당이 무시되므로 의도적으로 여기서 제거.

    }

    stages {

        // ── Stage 1. 소스 코드 체크아웃 + 변경 감지 ──────────
        stage('1. 준비: 코드 가져오기') {
            steps {
                script {
                    env.FAILED_STAGE = "1. 소스 코드 체크아웃"
                }
                // Jenkins에 연결된 SCM(Git 등)에서 소스 코드를 워크스페이스로 체크아웃
                checkout scm
                script {
                    env.FAILED_STAGE = "1. 변경 서비스 감지"

                    // 머지 commit(--no-ff) 의 HEAD~1..HEAD 가 빈 결과로 떨어지던 문제 해결:
                    //   - merge commit 이면 두 parent 사이 diff (PR 전체 변경 포착)
                    //   - 일반 commit / squash merge 면 HEAD~1 vs HEAD
                    //   - shallow clone 자동 unshallow (옛 commit 들 fetch)
                    //   - HEAD~1 없는 경우(첫 커밋 등) 전체 빌드로 폴백
                    def diff = sh(
                        script: '''
                            set +e

                            # shallow clone 이면 unshallow (옛 commit / 두 번째 parent fetch 보장)
                            if [ -f .git/shallow ]; then
                                echo "▶ shallow clone 감지 — unshallow 시도" >&2
                                git fetch --unshallow 2>/dev/null || git fetch --depth=100 2>/dev/null
                            fi

                            # HEAD 의 parent 갯수로 merge commit 판별 (2개 이상이면 merge)
                            PARENTS=$(git cat-file -p HEAD | grep -c '^parent ')

                            if [ "$PARENTS" -gt 1 ]; then
                                echo "▶ merge commit (parents=$PARENTS) — HEAD^1 vs HEAD^2 diff" >&2
                                git diff --name-only HEAD^1 HEAD^2
                            elif git rev-parse HEAD~1 >/dev/null 2>&1; then
                                echo "▶ 일반 commit — HEAD~1 vs HEAD diff" >&2
                                git diff --name-only HEAD~1 HEAD
                            else
                                echo "▶ HEAD~1 없음 — ALL 폴백" >&2
                                echo "ALL"
                            fi
                        ''',
                        returnStdout: true
                    ).trim()

                    echo "▶ 감지된 변경 파일:\n${diff}"
                    echo "▶ diff 길이: ${diff.length()}, 빈 문자열?: ${diff.isEmpty()}"
                    echo "▶ contains 검증 — infra/: ${diff.contains('infra/')} | backend/: ${diff.contains('backend/')} | frontend/: ${diff.contains('frontend/')} | ai_agent/: ${diff.contains('ai_agent/')}"

                    // infra/ 변경 시 yaml·Jenkinsfile도 배포에 영향을 주므로 전체 재빌드
                    def forceAll = (diff == 'ALL') || diff.contains('infra/')
                    echo "▶ forceAll: ${forceAll}"

                    env.BUILD_BACKEND  = (forceAll || diff.contains('backend/'))         ? 'true' : 'false'
                    env.BUILD_FRONTEND = (forceAll || diff.contains('frontend/'))        ? 'true' : 'false'
                    env.BUILD_AI       = (forceAll || diff.contains('ai_agent/'))        ? 'true' : 'false'
                    env.BUILD_ANALYSIS = (forceAll || diff.contains('analysis_server/')) ? 'true' : 'false'

                    echo "▶ 빌드 대상 — backend:${env.BUILD_BACKEND} | frontend:${env.BUILD_FRONTEND} | ai-agent:${env.BUILD_AI} | analysis:${env.BUILD_ANALYSIS}"
                }
            }
        }

        // ── Stage 2. Docker 이미지 빌드 및 ECR 푸시 ──────────
        stage('2. 빌드: 컨테이너 이미지 생성 및 푸시') {
            steps {
                script {
                    // ECR URI를 Credentials에서 가져옴
                    withCredentials([
                        string(credentialsId: "${REGISTRY_BE_ID}",       variable: 'FULL_URI_BE'),
                        string(credentialsId: "${REGISTRY_FE_ID}",       variable: 'FULL_URI_FE'),
                        string(credentialsId: "${REGISTRY_AI_ID}",       variable: 'FULL_URI_AI'),
                        string(credentialsId: "${REGISTRY_ANALYSIS_ID}", variable: 'FULL_URI_ANALYSIS'),
                        string(credentialsId: 'VITE_KAKAO_CLIENT_ID',    variable: 'VITE_KAKAO_CLIENT_ID')
                    ]) {
                        // ECR 호스트(레지스트리 도메인)만 추출 — 마지막 '/' 이전 문자열
                        def beRegistry = FULL_URI_BE.substring(0, FULL_URI_BE.lastIndexOf('/'))
                        def feRegistry = FULL_URI_FE.substring(0, FULL_URI_FE.lastIndexOf('/'))

                        // BE/FE가 서로 다른 ECR 호스트를 가리키면 설정 오류이므로 즉시 중단
                        if (beRegistry != feRegistry) {
                            error "ECR 호스트 불일치: BE(${beRegistry}) vs FE(${feRegistry})"
                        }

                        // docker.withRegistry에 전달할 URL 형식으로 변환 (https:// 접두사 보장)
                        def registryDomain = beRegistry.startsWith('http') ? beRegistry : "https://${beRegistry}"

                        // ECR 로그인 — Jenkins ECR 플러그인이 ecr:<region>:<credId> 형식으로 처리
                        docker.withRegistry("${registryDomain}", "ecr:${AWS_REGION}:${AWS_CRED_ID}") {

                            // ── 2-1. 백엔드 이미지 빌드 및 푸시 ─────────────
                            if (env.BUILD_BACKEND == 'true') {
                                try {
                                    env.FAILED_STAGE = "2-1. 백엔드 빌드 및 푸시"
                                    // BUILD_NUMBER 태그와 latest 태그를 동시에 부여
                                    // latest: 다음 배포에서 스킵된 서비스의 fallback 태그로 사용
                                    sh '''
                                    {
                                      docker build -t "$FULL_URI_BE:$BUILD_NUMBER" -t "$FULL_URI_BE:latest" backend
                                      docker push "$FULL_URI_BE:$BUILD_NUMBER"
                                      docker push "$FULL_URI_BE:latest"
                                    } 2> backend/be_err.log
                                    '''
                                } catch (Exception e) {
                                    def log = sh(
                                        script: '[ -f backend/be_err.log ] && tail -n 15 backend/be_err.log || echo "로그 없음"',
                                        returnStdout: true
                                    ).trim()
                                    env.ERROR_DETAILS = """📦 **Docker Build/Push Fail (Backend)**
${log}
"""
                                    error "Backend Build/Push Failed"
                                }
                            } else {
                                echo "백엔드 변경 없음 — 빌드 스킵 (현재 배포 이미지 유지)"
                            }

                            // ── 2-2. 프론트엔드 이미지 빌드 및 푸시 ─────────
                            if (env.BUILD_FRONTEND == 'true') {
                                try {
                                    env.FAILED_STAGE = "2-2. 프론트엔드 빌드 및 푸시"
                                    sh '''
                                    {
                                      docker build \
                                        --build-arg VITE_KAKAO_CLIENT_ID="$VITE_KAKAO_CLIENT_ID" \
                                        --build-arg NGINX_CONF=nginx.k8s.conf \
                                        -t "$FULL_URI_FE:$BUILD_NUMBER" \
                                        -t "$FULL_URI_FE:latest" \
                                        frontend
                                      docker push "$FULL_URI_FE:$BUILD_NUMBER"
                                      docker push "$FULL_URI_FE:latest"
                                    } 2> frontend/fe_err.log
                                    '''
                                } catch (Exception e) {
                                    def log = sh(
                                        script: '[ -f frontend/fe_err.log ] && tail -n 15 frontend/fe_err.log || echo "로그 없음"',
                                        returnStdout: true
                                    ).trim()
                                    env.ERROR_DETAILS = """📦 **Docker Build/Push Fail (Frontend)**
${log}
"""
                                    error "Frontend Build/Push Failed"
                                }
                            } else {
                                echo "프론트엔드 변경 없음 — 빌드 스킵 (현재 배포 이미지 유지)"
                            }

                            // ── 2-3. AI Agent 이미지 빌드 및 푸시 ────────────
                            if (env.BUILD_AI == 'true') {
                                try {
                                    env.FAILED_STAGE = "2-3. AI Agent 빌드 및 푸시"
                                    sh '''
                                    {
                                      docker build -t "$FULL_URI_AI:$BUILD_NUMBER" -t "$FULL_URI_AI:latest" ai_agent
                                      docker push "$FULL_URI_AI:$BUILD_NUMBER"
                                      docker push "$FULL_URI_AI:latest"
                                    } 2> ai_agent/ai_err.log
                                    '''
                                } catch (Exception e) {
                                    def log = sh(
                                        script: '[ -f ai_agent/ai_err.log ] && tail -n 15 ai_agent/ai_err.log || echo "로그 없음"',
                                        returnStdout: true
                                    ).trim()
                                    env.ERROR_DETAILS = """📦 **Docker Build/Push Fail (AI Agent)**
${log}
"""
                                    error "AI Agent Build/Push Failed"
                                }
                            } else {
                                echo "AI Agent 변경 없음 — 빌드 스킵 (현재 배포 이미지 유지)"
                            }

                            // ── 2-4. Analysis Server 이미지 빌드 및 푸시 ─────
                            if (env.BUILD_ANALYSIS == 'true') {
                                try {
                                    env.FAILED_STAGE = "2-4. Analysis Server 빌드 및 푸시"
                                    sh '''
                                    {
                                      docker build -t "$FULL_URI_ANALYSIS:$BUILD_NUMBER" -t "$FULL_URI_ANALYSIS:latest" analysis_server
                                      docker push "$FULL_URI_ANALYSIS:$BUILD_NUMBER"
                                      docker push "$FULL_URI_ANALYSIS:latest"
                                    } 2> analysis_server/analysis_err.log
                                    '''
                                } catch (Exception e) {
                                    def log = sh(
                                        script: '[ -f analysis_server/analysis_err.log ] && tail -n 15 analysis_server/analysis_err.log || echo "로그 없음"',
                                        returnStdout: true
                                    ).trim()
                                    env.ERROR_DETAILS = """📦 **Docker Build/Push Fail (Analysis Server)**
${log}
"""
                                    error "Analysis Server Build/Push Failed"
                                }
                            } else {
                                echo "Analysis Server 변경 없음 — 빌드 스킵 (현재 배포 이미지 유지)"
                            }
                        }
                    }
                }
            }
        }

        // ── Stage 3. SSAFY K3s 배포 (develop 브랜치 전용) ───
        stage('3. 배포: SSAFY K3s (Develop)') {
            // develop 브랜치에서만 실행
            when { branch 'develop' }
            steps {
                script {
                    env.FAILED_STAGE = "3. SSAFY K3s 클러스터 배포"
                    deployToCluster("${K3S_CONFIG_ID}", "SSAFY K3s")
                }
            }
        }

        // ── Stage 4. AWS EKS 배포 (main 브랜치 전용) ─────────
        stage('4. 배포: AWS EKS (Main)') {
            // main 브랜치에서만 실행
            when { branch 'main' }
            steps {
                script {
                    env.FAILED_STAGE = "4. AWS EKS 운영 환경 배포"
                    deployToCluster("${EKS_CONFIG_ID}", "AWS EKS")
                }
            }
        }
    }

    // ── Post Actions ─────────────────────────────────────────
    post {

        // 파이프라인 성공 시 Mattermost로 성공 알림 전송
        success {
            script {
                def author = sh(script: 'git log -1 --pretty=format:"%an"', returnStdout: true).trim()

                // 실제로 빌드된 서비스 목록 생성
                def builtServices = []
                if (env.BUILD_BACKEND  == 'true') builtServices.add('BE')
                if (env.BUILD_FRONTEND == 'true') builtServices.add('FE')
                if (env.BUILD_AI       == 'true') builtServices.add('AI')
                if (env.BUILD_ANALYSIS == 'true') builtServices.add('ANALYSIS')
                def builtLabel = builtServices ? builtServices.join('/') : '변경 없음'

                def stageFlow = ""
                def resultMsg = ""
                if (env.BRANCH_NAME == 'develop') {
                    stageFlow = "✅ ${builtLabel} 이미지 빌드 → 🚀 SSAFY K3s 배포"
                    resultMsg = "🚀 **SSAFY K3s** 배포 성공!"
                } else if (env.BRANCH_NAME == 'main') {
                    stageFlow = "✅ ${builtLabel} 이미지 빌드 → 🌟 AWS EKS 배포"
                    resultMsg = "🌟 **AWS EKS** 운영 환경 배포 성공!"
                } else {
                    stageFlow = "✅ ${builtLabel} 이미지 빌드"
                    resultMsg = "✅ 빌드 성공 (배포 미대상 브랜치)"
                }

                env.FAILED_STAGE = ""
                sendMattermostNotification("SUCCESS", "#00FF00", """${resultMsg}

**진행 단계:** ${stageFlow}
**작업자:** ${author}
**브랜치:** ${env.BRANCH_NAME}""")
            }
        }

        // 파이프라인 실패 시 실패 지점과 상세 원인을 포함한 알림 전송
        failure {
            script {
                def author = sh(script: 'git log -1 --pretty=format:"%an"', returnStdout: true).trim()
                sendMattermostNotification("FAILURE", "#FF0000", """🚨 **공정 실패 리포트**

**실패 지점:** `${env.FAILED_STAGE}`
**작업자:** ${author}
**브랜치:** ${env.BRANCH_NAME}

**상세 원인:**
${env.ERROR_DETAILS}""")
            }
        }

        // 성공/실패 관계없이 항상 실행 — 미사용 Docker 이미지 정리
        // '|| true': 다른 빌드가 동시에 prune 중이면 "a prune operation is already running"
        //            에러로 exit 1 → 정상 빌드가 FAILURE 로 오인되므로 정리 실패는 무시한다.
        always {
            sh "docker image prune -f || true"
        }
    }
}

// ============================================================
// [함수] deployToCluster
// 지정된 Kubernetes 클러스터에 백엔드/프론트엔드/AI Agent를 배포합니다.
//
// 이미지 태그 결정 전략:
//   - 빌드된 서비스: BUILD_NUMBER 태그 사용
//   - 스킵된 서비스: kubectl로 현재 배포 이미지를 읽어 그대로 재사용
//     → 태그 변경 없음 → K8s 변경 감지 안 함 → Pod 재시작 없음
//     → 최초 배포(Deployment 없음)이면 :latest 폴백
//
// @param configId    Jenkins에 등록된 kubeconfig 파일 Credentials ID
// @param clusterName 로그/알림에 표시할 클러스터 이름
// ============================================================
def deployToCluster(String configId, String clusterName) {
    try {
        // 이전 빌드의 deploy.err가 잔존할 경우 stale 로그가 오인될 수 있으므로
        // 배포 시작 전에 파일을 빈 상태로 초기화 (없으면 새로 생성)
        writeFile file: 'deploy.err', text: ''

        // AWS CLI가 포함된 공식 이미지를 사용하여 격리된 환경에서 배포 실행
        // --network host : 클러스터 API 서버 접근을 위해 호스트 네트워크 사용
        // --entrypoint="" : 이미지 기본 ENTRYPOINT를 비활성화
        docker.image('amazon/aws-cli:latest').inside('--network host --entrypoint=""') {
            withCredentials([
                // kubeconfig 파일을 KUBECONFIG 환경변수 경로로 마운트
                file(credentialsId: configId, variable: 'KUBECONFIG'),
                // ECR 백엔드 이미지 URI
                string(credentialsId: "${REGISTRY_BE_ID}", variable: 'FULL_URI_BE'),
                // ECR 프론트엔드 이미지 URI
                string(credentialsId: "${REGISTRY_FE_ID}", variable: 'FULL_URI_FE'),
                // ECR AI Agent 이미지 URI
                string(credentialsId: "${REGISTRY_AI_ID}", variable: 'FULL_URI_AI'),
                // ECR Analysis Server 이미지 URI
                string(credentialsId: "${REGISTRY_ANALYSIS_ID}", variable: 'FULL_URI_ANALYSIS'),
                // AWS IAM 자격증명 — $class 참조 방식으로 AmazonWebServicesCredentialsBinding 사용
                // (표준 Jenkins AWS Credentials Plugin 문법)
                [$class          : 'AmazonWebServicesCredentialsBinding',
                 credentialsId   : "${AWS_CRED_ID}",
                 accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                 secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]
            ]) {
                withEnv([
                    "BUILD_BACKEND=${env.BUILD_BACKEND}",
                    "BUILD_FRONTEND=${env.BUILD_FRONTEND}",
                    "BUILD_AI=${env.BUILD_AI}",
                    "BUILD_ANALYSIS=${env.BUILD_ANALYSIS}"
                ]) {
                    sh '''
                    {
                        set -e -o pipefail

                        # ── Step 1. kubectl 설치 및 무결성 검증 ──────────────
                        KUBECTL_VERSION="$(curl -L -s https://dl.k8s.io/release/stable.txt)"
                        curl -LO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl"
                        curl -LO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl.sha256"
                        echo "$(cat kubectl.sha256)  kubectl" | sha256sum --check
                        chmod +x kubectl
                        mv kubectl /usr/local/bin/

                        # ── Step 2. 네임스페이스 준비 ─────────────────────────
                        ECR_SERVER="${FULL_URI_BE%%/*}"
                        kubectl --kubeconfig=$KUBECONFIG apply -f $K8S_DIR/00_namespace.yaml

                        # ── Step 3. ECR 인증 시크릿(regcred) 갱신 ────────────
                        kubectl --kubeconfig=$KUBECONFIG create secret docker-registry regcred \
                          --docker-server="$ECR_SERVER" \
                          --docker-username=AWS \
                          --docker-password="$(aws ecr get-login-password --region ${AWS_REGION})" \
                          -n modu-apps \
                          --dry-run=client -o yaml | kubectl --kubeconfig=$KUBECONFIG apply -f -

                        # ── Step 4. 이미지 결정 ───────────────────────────────
                        # 빌드된 서비스: BUILD_NUMBER 태그 사용
                        # 스킵된 서비스: 현재 K8s 배포 이미지 재사용 → Pod 재시작 없음
                        #               최초 배포(Deployment 없음)이면 :latest 폴백

                        if [ "$BUILD_BACKEND" = "true" ]; then
                            BE_IMAGE="$FULL_URI_BE:$BUILD_NUMBER"
                        else
                            if kubectl --kubeconfig=$KUBECONFIG get deployment modu-backend -n modu-apps >/dev/null 2>&1; then
                                BE_IMAGE=$(kubectl --kubeconfig=$KUBECONFIG get deployment modu-backend \
                                    -n modu-apps \
                                    -o jsonpath='{.spec.template.spec.containers[0].image}')
                                [ -z "$BE_IMAGE" ] && { echo "❌ modu-backend 이미지 값이 비어있습니다."; exit 1; }
                            else
                                echo "⚠️ modu-backend Deployment 없음 — :latest 폴백"
                                BE_IMAGE="$FULL_URI_BE:latest"
                            fi
                        fi

                        if [ "$BUILD_FRONTEND" = "true" ]; then
                            FE_IMAGE="$FULL_URI_FE:$BUILD_NUMBER"
                        else
                            if kubectl --kubeconfig=$KUBECONFIG get deployment modu-frontend -n modu-apps >/dev/null 2>&1; then
                                FE_IMAGE=$(kubectl --kubeconfig=$KUBECONFIG get deployment modu-frontend \
                                    -n modu-apps \
                                    -o jsonpath='{.spec.template.spec.containers[0].image}')
                                [ -z "$FE_IMAGE" ] && { echo "❌ modu-frontend 이미지 값이 비어있습니다."; exit 1; }
                            else
                                echo "⚠️ modu-frontend Deployment 없음 — :latest 폴백"
                                FE_IMAGE="$FULL_URI_FE:latest"
                            fi
                        fi

                        if [ "$BUILD_AI" = "true" ]; then
                            AI_IMAGE="$FULL_URI_AI:$BUILD_NUMBER"
                        else
                            if kubectl --kubeconfig=$KUBECONFIG get deployment modu-ai-agent -n modu-apps >/dev/null 2>&1; then
                                AI_IMAGE=$(kubectl --kubeconfig=$KUBECONFIG get deployment modu-ai-agent \
                                    -n modu-apps \
                                    -o jsonpath='{.spec.template.spec.containers[0].image}')
                                [ -z "$AI_IMAGE" ] && { echo "❌ modu-ai-agent 이미지 값이 비어있습니다."; exit 1; }
                            else
                                echo "⚠️ modu-ai-agent Deployment 없음 — :latest 폴백"
                                AI_IMAGE="$FULL_URI_AI:latest"
                            fi
                        fi

                        if [ "$BUILD_ANALYSIS" = "true" ]; then
                            ANALYSIS_IMAGE="$FULL_URI_ANALYSIS:$BUILD_NUMBER"
                        else
                            # 5개 워크로드가 같은 이미지를 공유하므로 engine 의 이미지를 기준으로 추적
                            if kubectl --kubeconfig=$KUBECONFIG get deployment modu-analysis-engine -n modu-apps >/dev/null 2>&1; then
                                ANALYSIS_IMAGE=$(kubectl --kubeconfig=$KUBECONFIG get deployment modu-analysis-engine \
                                    -n modu-apps \
                                    -o jsonpath='{.spec.template.spec.containers[0].image}')
                                [ -z "$ANALYSIS_IMAGE" ] && { echo "❌ modu-analysis-engine 이미지 값이 비어있습니다."; exit 1; }
                            else
                                echo "⚠️ modu-analysis-engine Deployment 없음 — :latest 폴백"
                                ANALYSIS_IMAGE="$FULL_URI_ANALYSIS:latest"
                            fi
                        fi

                        echo "▶ 배포 이미지 — BE: $BE_IMAGE | FE: $FE_IMAGE | AI: $AI_IMAGE | ANALYSIS: $ANALYSIS_IMAGE"

                        # ── Step 5. 이미지 태그 치환 및 배포 ─────────────────
                        DEPLOY_DIR=$(mktemp -d)
                        cp $K8S_DIR/*.yaml "$DEPLOY_DIR/"
                        sed -i "s|BACKEND_IMAGE|${BE_IMAGE}|g"      "$DEPLOY_DIR/backend.yaml"
                        sed -i "s|BACKEND_IMAGE|${BE_IMAGE}|g"      "$DEPLOY_DIR/kis-gateway.yaml"
                        sed -i "s|FRONTEND_IMAGE|${FE_IMAGE}|g"     "$DEPLOY_DIR/frontend.yaml"
                        sed -i "s|AIAGENT_IMAGE|${AI_IMAGE}|g"      "$DEPLOY_DIR/ai-agent.yaml"
                        sed -i "s|ANALYSIS_IMAGE|${ANALYSIS_IMAGE}|g" "$DEPLOY_DIR/analysis-server.yaml"
                        kubectl --kubeconfig=$KUBECONFIG apply -f "$DEPLOY_DIR/"
                        rm -rf "$DEPLOY_DIR"

                    } 2> deploy.err
                    '''
                }
            }
        }
    } catch (Exception e) {
        // 셸 스크립트 에러 로그가 있으면 우선 사용 (더 구체적인 원인 제공)
        def shellLog = sh(
            script: "[ -f deploy.err ] && tail -n 15 deploy.err || echo ''",
            returnStdout: true
        ).trim()

        if (shellLog) {
            // 셸 스크립트 레벨 에러 — 인프라 설정 오류일 가능성 높음
            env.ERROR_DETAILS = "🛠️ **Infrastructure Script Error**\n```bash\n${shellLog}\n```"
        } else {
            // Groovy/Jenkins 엔진 레벨 에러 — 파이프라인 코드 자체 문제일 가능성 높음
            env.ERROR_DETAILS = "⚙️ **Jenkins Pipeline Engine Error**\n> ${e.toString()}"
        }
        error "Deployment Failed"
    }
}

// ============================================================
// [함수] sendMattermostNotification
// Mattermost Incoming Webhook으로 파이프라인 결과를 알립니다.
//
// @param status  "SUCCESS" 또는 "FAILURE"
// @param color   Mattermost 첨부파일 사이드 색상 (hex)
// @param message 알림 본문 (마크다운 지원)
// ============================================================
def sendMattermostNotification(String status, String color, String message) {
    // URL 인코딩된 Job 이름을 사람이 읽기 쉬운 형태로 디코딩
    def decodedJobName = java.net.URLDecoder.decode(env.JOB_NAME, "UTF-8")

    withCredentials([string(credentialsId: 'MATTERMOST_WEBHOOK_URL', variable: 'WEBHOOK_URL')]) {
        def title = (status == "SUCCESS") ? "✅ 파이프라인 공정 성공" : "🚨 파이프라인 공정 실패"

        def fullText = "### **Project:** ${decodedJobName} (#${env.BUILD_NUMBER})\n${message}\n\n---\n[🔍 젠킨스 상세 로그 확인](${env.BUILD_URL}console)"

        // JSON 삽입 전 특수문자 이스케이프 (백슬래시 → 개행 → 따옴표 순서 중요)
        def escapedText = fullText
            .replace('\\', '\\\\')
            .replace('"',  '\\"')
            .replace('\n', '\\n')
            .replace('\r', '\\r')
            .replace('\t', '\\t')

        def escapedTitle = title.replace('"', '\\"')

        // JSON을 파일로 저장 후 전송 (인라인 -d 방식은 개행/특수문자로 JSON이 깨짐)
        writeFile file: 'mm_payload.json', text: """{"attachments":[{"color":"${color}","title":"${escapedTitle}","text":"${escapedText}"}]}"""
        sh 'curl -s -X POST -H "Content-Type: application/json" --data @mm_payload.json "$WEBHOOK_URL"'
    }
}
