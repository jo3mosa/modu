# =====================================================
# AI Agent — 로컬 실행 환경변수 템플릿
# 실제 값은 .env 에 채우고 커밋하지 마세요 (.env는 gitignore).
# =====================================================

# --- LLM (필수) ---
# SSAFY GMS 프록시 키 — app/config/llm.py에서 사용
GMS_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Database (memory_agent / context_loader 필수) ---
# 형식: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=

# --- LangSmith (선택, 측정 인프라) ---
# 활성화하면 토큰/비용/latency가 자동 기록되고
# observability.langsmith_helpers의 도메인 metadata 태깅이 수집된다.
# 비활성화 상태(미설정 또는 false)에서도 그래프는 정상 동작한다.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=modu-mvp
