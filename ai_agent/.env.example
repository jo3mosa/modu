# =====================================================
# AI Agent — 로컬 실행 환경변수 템플릿
# 실제 값은 .env 에 채우고 커밋하지 마세요 (.env는 gitignore).
# =====================================================

# --- LLM (필수) ---
# MODEL_PROFILE이 가리키는 provider의 키 1개 이상 필수.
# 가용 profile (app/config/llm.py _PROFILES dict):
#   gms_4o_mini / gms_4o            → GMS_KEY 필요
#   claude_haiku / claude_sonnet / claude_opus → ANTHROPIC_API_KEY 필요
#   grok_2 / grok_3                 → XAI_API_KEY 필요
GMS_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# 현재 사용할 LLM profile (미설정 시 gms_4o_mini)
MODEL_PROFILE=gms_4o_mini

# --- Database (memory_agent / context_loader 필수) ---
# 형식: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=

# --- Kafka (실시간 파이프만 필요. backtest는 불필요) ---
# consumer.py / run_and_publish 경로에서만 사용된다.
# backtest CLI(app.backtest.cli)는 Kafka에 의존하지 않으므로 미설정해도 동작한다.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- LangSmith (선택, 측정 인프라) ---
# 활성화하면 토큰/비용/latency가 자동 기록되고
# observability.langsmith_helpers의 도메인 metadata 태깅이 수집된다.
# 비활성화 상태(미설정 또는 false)에서도 그래프는 정상 동작한다.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=modu-mvp

# =====================================================
# Backtest 모듈 (app.backtest.cli) 실행 시 필요한 환경
# =====================================================
# 위 GMS_KEY + DATABASE_URL만 있으면 backtest CLI가 동작한다.
# Kafka / KIS API / LangSmith는 backtest 경로에서 호출되지 않는다.
#
# --use-memory 플래그를 쓰면 결정이 ai_judgments 테이블에 시뮬레이션 시각으로 저장되어
# 동일 user_id의 retrieval이 시간 누적 효과를 그대로 반영한다 (콜드 스타트 → 자연 누적).
#
# 사용 예:
#   python -m app.backtest.cli \
#     --user-id 1 --stocks 005930,000660 \
#     --start 2025-01-02 --end 2025-12-30 \
#     --output runs/backtest_2025.jsonl \
#     --use-memory --score-after
